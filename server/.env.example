PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
MONGODB_URI=mongodb://127.0.0.1:27017/tapraj-portfolio

PRIMARY_EMAIL=your-primary-email@example.com
SECONDARY_EMAIL=your-secondary-sender@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-secondary-sender@example.com
SMTP_PASS=your-app-password

# Many SMTP providers reject arbitrary "from" addresses. Keep false unless your provider allows it.
ALLOW_VISITOR_FROM=false

# Optional, reserved for future uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
